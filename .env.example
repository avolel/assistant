# LLM
ASSISTANT_LLM_PROVIDER=<LLM Provider>
ASSISTANT_LLM_MODEL=<LLM Model>
ASSISTANT_LLM_BASE_URL=<LLM Base URL>
ASSISTANT_LLM_TEMPERATURE=<TEMPERATURE>
 
# Embeddings
ASSISTANT_EMBED_MODEL=<Embedding Model>
 
# Memory
ASSISTANT_STM_MAX_TURNS=<MAX_TURNS>
ASSISTANT_LTM_N_RESULTS=<N_RESULTS>
 
# Voice (set to true to enable)
ASSISTANT_VOICE_ENABLED=<true/false>
ASSISTANT_STT_MODEL_SIZE=<STT Model Size>
 
# Owner (filled by setup wizard)
ASSISTANT_OWNER_NAME=<OWNERS NAME>
ASSISTANT_OWNER_EMAIL=<OWNERS EMAIL>
ASSISTANT_OWNER_TIMEZONE=<OWNERS TIMEZONE>

ASSISTANT_NAME=Aria